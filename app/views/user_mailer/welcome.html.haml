= content_for :heading do
  = render 'application/mailer/heading',
           subtitle: t('user_mailer.welcome.explanation'),
           title: t('user_mailer.welcome.title', name: @resource.account.username)

%table.email-w-full{ cellspacing: 0, cellpadding: 0, border: 0, role: 'presentation' }
  %tr
    %td.email-body-huge-padding-td
      %h2.email-h2= t('user_mailer.welcome.intro.primary')
      %p.email-h-sub= t('user_mailer.welcome.intro.secondary')
      = render 'application/mailer/button', text: t('user_mailer.welcome.sign_in_action'), url: new_user_session_url, has_arrow: false

%table.email-w-full{ cellspacing: 0, cellpadding: 0, border: 0, role: 'presentation' }
  %tr
    %td.email-body-padding-td.email-body-padding-top-0
      %h2.email-h2= t('user_mailer.welcome.steps_title')

      %table.email-w-full.email-inner-card-table.email-welcome-step-card{ cellspacing: 0, cellpadding: 0, border: 0, role: 'presentation' }
        %tr
          %td.email-inner-card-td
            %h3.email-welcome-step-title 1. #{t('user_mailer.welcome.categories.title')}
            %p.email-p.email-welcome-step-body= t('user_mailer.welcome.categories.body')
            = image_tag frontend_asset_url('images/highlander/onboarding/highlander-categories.png'), alt: t('user_mailer.welcome.categories.image_alt'), class: 'email-welcome-step-image'

      %table.email-w-full.email-inner-card-table.email-welcome-step-card{ cellspacing: 0, cellpadding: 0, border: 0, role: 'presentation' }
        %tr
          %td.email-inner-card-td
            %h3.email-welcome-step-title 2. #{t('user_mailer.welcome.notifications.title')}
            %p.email-p.email-welcome-step-body= t('user_mailer.welcome.notifications.body')
            = image_tag frontend_asset_url('images/highlander/onboarding/highlander-notifications.png'), alt: t('user_mailer.welcome.notifications.image_alt'), class: 'email-welcome-step-image'

      %table.email-w-full.email-inner-card-table{ cellspacing: 0, cellpadding: 0, border: 0, role: 'presentation' }
        %tr
          %td.email-inner-card-td
            %h3.email-welcome-step-title 3. #{t('user_mailer.welcome.install.title')}
            %p.email-p.email-welcome-step-body= t('user_mailer.welcome.install.body')

            %h4.email-welcome-step-subtitle= t('user_mailer.welcome.install.iphone.title')
            %table.email-w-full.email-welcome-callout-table{ cellspacing: 0, cellpadding: 0, border: 0, role: 'presentation' }
              %tr
                %td.email-welcome-callout-td
                  %p.email-welcome-callout-p
                    %strong= t('user_mailer.welcome.install.iphone.warning_title')
                    = t('user_mailer.welcome.install.iphone.warning_body')
            .email-prose
              %ol.email-welcome-list
                - t('user_mailer.welcome.install.iphone.steps').each do |step|
                  %li.email-welcome-list-item= step

            %h4.email-welcome-step-subtitle= t('user_mailer.welcome.install.android.title')
            .email-prose
              %ol.email-welcome-list.email-welcome-list-tight
                - t('user_mailer.welcome.install.android.steps').each do |step|
                  %li.email-welcome-list-item= step
